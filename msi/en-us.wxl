  <String Id="WelcomeDlgDescription"
          Value="The .msi starts a server at http://127.0.0.1:3000. If the port is occupied, edit [INSTALLFOLDER]grepfeed.xml aftewards and manually restart the service. Logs: $env:SystemRoot/Temp/grepfeed*." />
